<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="notpattern.MainWindow"
        Width="600" Height="500"
        Title="Sneaker Builder">

  <StackPanel Margin="10" Spacing="5">

      <TextBlock Text="Логи:" FontWeight="Bold"/>
      <TextBox x:Name="LogBox" Height="80" IsReadOnly="True" TextWrapping="Wrap"/>

      <TextBlock Text="Результат:" FontWeight="Bold"/>
      <TextBox x:Name="ResultBox" Height="100" IsReadOnly="True" TextWrapping="Wrap"/>

      <ProgressBar x:Name="Progress" Minimum="0" Maximum="100" Height="20"/>

      <Separator/>

      <TextBlock Text="Назначение:" FontWeight="Bold"/>

      <RadioButton x:Name="VolleyballRB" Content="Волейбол" GroupName="Type"/>
      <RadioButton x:Name="UrbanRB" Content="Город" GroupName="Type"/>
      <RadioButton x:Name="CollabRB" Content="Коллекционная" GroupName="Type"/>

      <Separator/>

      <TextBlock Text="Доп. опции:" FontWeight="Bold"/>

      <CheckBox x:Name="GelCB" Content="Гель (амортизация)"/>
      <CheckBox x:Name="ReinforcedSoleCB" Content="Усиленная подошва"/>
      <CheckBox x:Name="PremiumUpperCB" Content="Премиальный верх"/>

      <StackPanel Orientation="Horizontal">
          <CheckBox x:Name="CollabCB" Content="Коллаборация"/>
          <ComboBox x:Name="CollabBrandBox" Width="120">
              <ComboBoxItem Content="Nike"/>
              <ComboBoxItem Content="Adidas"/>
              <ComboBoxItem Content="Supreme"/>
          </ComboBox>
      </StackPanel>

      <Button Content="Собрать кроссовок"
              Click="BuildButton_Click"
              Margin="0,10,0,0"/>

      <Image x:Name="SneakerImage" Width="300" Height="200" Margin="0,10,0,0"/>

  </StackPanel>
</Window>